# ML Server Configuration
# Point to your backend ML inference server
ML_SERVER_URL=http://localhost:8000
ML_SERVER_TIMEOUT=30000

# Model Paths (if using local models on the server)
YOLOV9_MODEL_PATH=/models/yolov9.pt
ANOMALY_MODEL_PATH=/models/anomaly_detector.pth
SIAMESE_MODEL_PATH=/models/siamese_network.pt
CLASSIFICATION_MODEL_PATH=/models/classifier.h5

# Feature Flags
ENABLE_REFERENCE_IMAGE=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_IMAGE_COMPARISON=true
ENABLE_RISK_SCORING=true

# Risk Thresholds
RISK_THRESHOLD_HIGH=75
RISK_THRESHOLD_MEDIUM=45

# Model Performance Settings
YOLOV9_CONFIDENCE_THRESHOLD=0.5
YOLOV9_IOU_THRESHOLD=0.45
MAX_DETECTIONS=50

# Logging & Monitoring
LOG_LEVEL=info
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_DEBUG_MODE=false

# Security
ALLOW_UPLOAD_FORMATS=jpg,jpeg,png,gif
MAX_FILE_SIZE_MB=50
REQUIRE_API_KEY=false
# API_KEY=your-secret-key-here

# Analytics (optional)
ENABLE_ANALYTICS=false
ANALYTICS_ENDPOINT=https://analytics.example.com

# Caching (optional)
ENABLE_CACHE=false
CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379
